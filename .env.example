# AURA Configuration Template
# Copy this to .env and fill in your actual values

# Google Gemini API Key
# For single key:
GEMINI_API_KEY=your_gemini_api_key_here

# For multiple keys (to avoid rate limits), separate with commas:
# GEMINI_API_KEY=key1_here,key2_here,key3_here

# Google API Key (used by browser-use for AI browser automation)
# If not set, GEMINI_API_KEY will be used automatically
# GOOGLE_API_KEY=your_key_here

# Optional: OpenRouter API Key (for future features)
# OPENROUTER_API_KEY=your_openrouter_key_here

# Voice Settings
VOICE_LANGUAGE=en-US
WAKE_WORD=aura

# User Preferences
USER_NAME=Sir

# Telegram Bot (Remote Control from Phone)
# 1. Talk to @BotFather on Telegram → /newbot → get token
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to get chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
