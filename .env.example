# AURA Configuration Template
# Copy this to .env and fill in your actual values

# ============================================================
# GEMINI API KEYS - Per-Process Assignment
# ============================================================
# You can use the same key for all, or assign different keys
# to spread quota across separate Google AI Studio projects.

# Fallback / single key (used if a specific key is not set)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# FILE CREATION ANCHOR
# ============================================================
# Default directory where AURA saves all created files/documents
# when the user does NOT specify a location in their command.
# Change this to any folder you prefer (will be auto-created).
DEFAULT_FILES_DIR=C:\Users\YourName\OneDrive\Desktop\aura

# Key 1 - Used by the Intent Router (LLM intent classification)
GEMINI_API_KEY_INTENT=your_intent_key_here

# Key 2 - Used by the Code Generator (ai_client.py)
GEMINI_API_KEY_CODEGEN=your_codegen_key_here

# Key 3 - Used by the Browser Agent (browser_agent.py / browser-use)
GEMINI_API_KEY_BROWSER=your_browser_key_here

# Key 4 - Used by the Email Assistant (email_assistant.py)
GEMINI_API_KEY_EMAIL=your_email_key_here

# Key 5 - Used by the Agentic App Creator (app_creator.py)
GEMINI_API_KEY_APPCREATOR=your_appcreator_key_here

# ============================================================
# Optional: OpenRouter API Key (for future features)
# OPENROUTER_API_KEY=your_openrouter_key_here
# ============================================================

# Voice Settings
VOICE_LANGUAGE=en-US
WAKE_WORD=aura

# User Preferences
USER_NAME=Sir

# Telegram Bot (Remote Control from Phone)
# 1. Talk to @BotFather on Telegram → /newbot → get token
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to get chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
